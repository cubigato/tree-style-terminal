#!/bin/sh
set -eu

if [ -z "${APPDIR:-}" ]; then
    APPDIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
    export APPDIR
fi

if [ -n "${OWD:-}" ] && [ -d "$OWD" ]; then
    cd "$OWD"
fi

app_lib="$APPDIR/usr/lib"
app_multiarch_lib="$APPDIR/usr/lib/x86_64-linux-gnu"
runtime_cache="${XDG_RUNTIME_DIR:-/tmp}/tree-style-terminal-appimage-${USER:-user}"
mkdir -p "$runtime_cache"
chmod 0700 "$runtime_cache"

if [ "${LD_LIBRARY_PATH+x}" = x ]; then
    export TST_APPIMAGE_HOST_LD_LIBRARY_PATH="$LD_LIBRARY_PATH"
fi
if [ "${PYTHONHOME+x}" = x ]; then
    export TST_APPIMAGE_HOST_PYTHONHOME="$PYTHONHOME"
fi
if [ "${PYTHONPATH+x}" = x ]; then
    export TST_APPIMAGE_HOST_PYTHONPATH="$PYTHONPATH"
fi
if [ "${GI_TYPELIB_PATH+x}" = x ]; then
    export TST_APPIMAGE_HOST_GI_TYPELIB_PATH="$GI_TYPELIB_PATH"
fi
if [ "${GIO_EXTRA_MODULES+x}" = x ]; then
    export TST_APPIMAGE_HOST_GIO_EXTRA_MODULES="$GIO_EXTRA_MODULES"
fi
if [ "${GIO_MODULE_DIR+x}" = x ]; then
    export TST_APPIMAGE_HOST_GIO_MODULE_DIR="$GIO_MODULE_DIR"
fi
if [ "${GIO_USE_VFS+x}" = x ]; then
    export TST_APPIMAGE_HOST_GIO_USE_VFS="$GIO_USE_VFS"
fi
if [ "${GSETTINGS_SCHEMA_DIR+x}" = x ]; then
    export TST_APPIMAGE_HOST_GSETTINGS_SCHEMA_DIR="$GSETTINGS_SCHEMA_DIR"
fi
if [ "${XDG_DATA_DIRS+x}" = x ]; then
    export TST_APPIMAGE_HOST_XDG_DATA_DIRS="$XDG_DATA_DIRS"
fi
if [ "${XDG_CACHE_HOME+x}" = x ]; then
    export TST_APPIMAGE_HOST_XDG_CACHE_HOME="$XDG_CACHE_HOME"
fi
if [ "${GDK_PIXBUF_MODULE_FILE+x}" = x ]; then
    export TST_APPIMAGE_HOST_GDK_PIXBUF_MODULE_FILE="$GDK_PIXBUF_MODULE_FILE"
fi
if [ "${FONTCONFIG_FILE+x}" = x ]; then
    export TST_APPIMAGE_HOST_FONTCONFIG_FILE="$FONTCONFIG_FILE"
fi
if [ "${FONTCONFIG_SYSROOT+x}" = x ]; then
    export TST_APPIMAGE_HOST_FONTCONFIG_SYSROOT="$FONTCONFIG_SYSROOT"
fi
if [ "${GTK_IM_MODULE_FILE+x}" = x ]; then
    export TST_APPIMAGE_HOST_GTK_IM_MODULE_FILE="$GTK_IM_MODULE_FILE"
fi

export TST_APPIMAGE=1
export LD_LIBRARY_PATH="$app_lib:$app_multiarch_lib"
export PYTHONHOME="$APPDIR/usr"
export PYTHONPATH="$APPDIR/usr/lib/python3/dist-packages"
export GI_TYPELIB_PATH="$app_multiarch_lib/girepository-1.0"
export GIO_EXTRA_MODULES="$app_multiarch_lib/gio/modules"
export GIO_MODULE_DIR="$app_multiarch_lib/gio/modules"
export GIO_USE_VFS=local
export GSETTINGS_SCHEMA_DIR="$APPDIR/usr/share/glib-2.0/schemas"
export XDG_DATA_DIRS="$APPDIR/usr/share"
export XDG_CACHE_HOME="$runtime_cache/cache"
mkdir -p "$XDG_CACHE_HOME"
export FONTCONFIG_FILE="$APPDIR/etc/fonts/fontconfig-appimage.conf"
unset FONTCONFIG_SYSROOT

gdk_cache="$runtime_cache/gdk-pixbuf-loaders-$$.cache"
GDK_PIXBUF_MODULEDIR="$app_multiarch_lib/gdk-pixbuf-2.0/2.10.0/loaders" \
    "$APPDIR/usr/bin/gdk-pixbuf-query-loaders" >"$gdk_cache"
export GDK_PIXBUF_MODULE_FILE="$gdk_cache"

immodules_dir="$app_multiarch_lib/gtk-3.0/3.0.0/immodules"
if [ -d "$immodules_dir" ]; then
    immodules_cache="$runtime_cache/gtk-immodules-$$.cache"
    "$APPDIR/usr/bin/gtk-query-immodules-3.0" "$immodules_dir"/*.so \
        >"$immodules_cache"
    export GTK_IM_MODULE_FILE="$immodules_cache"
fi

if [ -z "${SSL_CERT_FILE:-}" ] && \
    [ -f "$APPDIR/etc/ssl/certs/ca-certificates.crt" ]; then
    export SSL_CERT_FILE="$APPDIR/etc/ssl/certs/ca-certificates.crt"
fi

exec "$APPDIR/usr/bin/python3" -c \
    'import sys; sys.argv[0] = "tree-style-terminal"; from tree_style_terminal.main import main; raise SystemExit(main())' \
    "$@"
