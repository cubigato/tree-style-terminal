FROM docker.io/library/debian:12-slim@sha256:35ae959f6e83ffb465e7614d27b4fddd28288caa551fbca2798367567cce80d3

ENV DEBIAN_FRONTEND=noninteractive

COPY packaging/appimage/debian.sources /etc/apt/sources.list.d/debian.sources

RUN rm -f /etc/apt/sources.list \
    && apt-get update \
    && apt-get install -y --no-install-recommends \
        appstream \
        binutils \
        ca-certificates \
        curl \
        desktop-file-utils \
        dpkg-dev \
        file \
        findutils \
        gir1.2-gtk-3.0 \
        gir1.2-vte-2.91 \
        git \
        libgdk-pixbuf2.0-bin \
        libglib2.0-bin \
        libgtk-3-bin \
        librsvg2-common \
        pax-utils \
        python3 \
        python3-gi \
        python3-yaml \
        shared-mime-info \
        squashfs-tools \
    && rm -rf /var/lib/apt/lists/*

ARG APPIMAGETOOL_URL=https://github.com/AppImage/appimagetool/releases/download/continuous/appimagetool-x86_64.AppImage
ARG APPIMAGETOOL_SHA256=a6d71e2b6cd66f8e8d16c37ad164658985e0cf5fcaa950c90a482890cb9d13e0
ARG APPIMAGE_RUNTIME_URL=https://github.com/AppImage/type2-runtime/releases/download/continuous/runtime-x86_64
ARG APPIMAGE_RUNTIME_SHA256=1cc49bcf1e2ccd593c379adb17c9f85a36d619088296504de95b1d06215aebbf
ARG APPIMAGE_RUNTIME_LICENSE_URL=https://raw.githubusercontent.com/AppImage/type2-runtime/75849dce7cc37e4319b633df1f116ca895c71a12/LICENSE
ARG APPIMAGE_RUNTIME_LICENSE_SHA256=aa154fc9070614bbe7921f89db11efd1dba7a1f3a41685958110e2230f9c0ca1

RUN curl -fsSL "$APPIMAGETOOL_URL" -o /tmp/appimagetool.AppImage \
    && echo "$APPIMAGETOOL_SHA256  /tmp/appimagetool.AppImage" | sha256sum --check --strict \
    && chmod 0755 /tmp/appimagetool.AppImage \
    && cd /tmp \
    && ./appimagetool.AppImage --appimage-extract >/dev/null \
    && mv /tmp/squashfs-root /opt/appimagetool \
    && ln -s /opt/appimagetool/AppRun /usr/local/bin/appimagetool \
    && curl -fsSL "$APPIMAGE_RUNTIME_URL" -o /opt/runtime-x86_64 \
    && echo "$APPIMAGE_RUNTIME_SHA256  /opt/runtime-x86_64" | sha256sum --check --strict \
    && chmod 0644 /opt/runtime-x86_64 \
    && curl -fsSL "$APPIMAGE_RUNTIME_LICENSE_URL" -o /opt/runtime-x86_64.LICENSE \
    && echo "$APPIMAGE_RUNTIME_LICENSE_SHA256  /opt/runtime-x86_64.LICENSE" | sha256sum --check --strict \
    && rm -f /tmp/appimagetool.AppImage

COPY packaging/appimage/container-build.sh /usr/local/bin/build-tree-style-terminal-appimage

ENTRYPOINT ["/usr/local/bin/build-tree-style-terminal-appimage"]
