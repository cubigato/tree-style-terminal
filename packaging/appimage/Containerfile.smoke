FROM docker.io/library/debian:12-slim@sha256:35ae959f6e83ffb465e7614d27b4fddd28288caa551fbca2798367567cce80d3

ENV DEBIAN_FRONTEND=noninteractive

COPY packaging/appimage/debian.sources /etc/apt/sources.list.d/debian.sources

RUN rm -f /etc/apt/sources.list \
    && apt-get update \
    && apt-get install -y --no-install-recommends \
        ca-certificates \
        file \
        weston \
        xauth \
        xvfb \
    && rm -rf /var/lib/apt/lists/*

COPY packaging/appimage/smoke.sh /usr/local/bin/check-tree-style-terminal-appimage

ENTRYPOINT ["/usr/local/bin/check-tree-style-terminal-appimage"]
